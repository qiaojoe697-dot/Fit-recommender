from __future__ import annotations

import json
import os
from pathlib import Path
from typing import Dict, List, Optional, Tuple

from src.model import OutfitRecord, UserProfile
from src.profile import jaccard_similarity, weighted_jaccard

_DATA_DIR = Path(__file__).resolve().parent.parent / "data"
_OUTFIT_API_URL = os.environ.get("OUTFIT_API_URL", "")

_SIMILAR_HIGH_COUNT = 10
_SIMILAR_LOW_COUNT = 10
_SIMILARITY_THRESHOLD = 0.3


# ─────────────────────────────
# 数据加载（带缓存优化 + 可观测日志）
# ─────────────────────────────

_cached_outfits: Optional[List[OutfitRecord]] = None


def load_outfits() -> List[OutfitRecord]:
    global _cached_outfits

    if _cached_outfits is not None:
        return _cached_outfits

    try:
        if _OUTFIT_API_URL:
            _cached_outfits = _load_from_api(_OUTFIT_API_URL)
        else:
            _cached_outfits = _load_from_json()
    except Exception as e:
        print(f"[WARN] load_outfits failed: {e}")
        _cached_outfits = _load_from_json()

    return _cached_outfits


def _load_from_json() -> List[OutfitRecord]:
    path = _DATA_DIR / "outfits.json"
    if not path.exists():
        return []

    with open(path, encoding="utf-8") as f:
        raw = json.load(f)

    return [
        OutfitRecord(
            id=d["id"],
            name=d["name"],
            tags=d.get("tags", []),
            popularity=d.get("popularity", 0),
        )
        for d in raw
    ]


def _load_from_api(url: str) -> List[OutfitRecord]:
    try:
        import urllib.request

        with urllib.request.urlopen(url, timeout=5) as resp:
            raw = json.loads(resp.read().decode())

        return [
            OutfitRecord(
                id=d["id"],
                name=d["name"],
                tags=d.get("tags", []),
                popularity=d.get("popularity", 0),
            )
            for d in raw
        ]

    except Exception as e:
        print(f"[WARN] API fallback triggered: {e}")
        return _load_from_json()


def build_outfit_map(outfits: List[OutfitRecord]) -> Dict[str, OutfitRecord]:
    return {o.id: o for o in outfits}


# ─────────────────────────────
# 首页推荐
# ─────────────────────────────

def recommend_for_user(
    profile: Optional[UserProfile],
    outfits: Optional[List[OutfitRecord]] = None,
    top_n: int = 10,
    use_weighted: bool = True,
    w_explicit: float = 2.0,
    w_implicit: float = 1.0,
) -> List[Tuple[OutfitRecord, float]]:

    outfits = outfits or load_outfits()

    # 冷启动
    if profile is None or not getattr(profile, "merged_tags", None):
        max_pop = max((o.popularity for o in outfits), default=1) or 1
        ranked = sorted(outfits, key=lambda o: o.popularity, reverse=True)

        return [
            (o, round(o.popularity / max_pop, 4))
            for o in ranked[:top_n]
        ]

    scored: List[Tuple[OutfitRecord, float]] = []

    for outfit in outfits:
        try:
            if use_weighted:
                score = weighted_jaccard(
                    profile.explicit_tags,
                    profile.implicit_tags,
                    outfit.tag_set(),
                    w_explicit,
                    w_implicit,
                )
            else:
                score = jaccard_similarity(
                    profile.merged_tags,
                    outfit.tag_set(),
                )

            scored.append((outfit, round(score, 4)))

        except Exception:
            continue

    scored.sort(key=lambda x: x[1], reverse=True)
    return scored[:top_n]


# ─────────────────────────────
# 详情页推荐（修复 high/low 逻辑）
# ─────────────────────────────

def recommend_similar(
    target_outfit_id: str,
    outfits: Optional[List[OutfitRecord]] = None,
    high_count: int = _SIMILAR_HIGH_COUNT,
    low_count: int = _SIMILAR_LOW_COUNT,
) -> Dict[str, List[Tuple[OutfitRecord, float]]]:

    outfits = outfits or load_outfits()
    outfit_map = build_outfit_map(outfits)

    target = outfit_map.get(target_outfit_id)
    if not target:
        return {"high": [], "low": []}

    target_tags = target.tag_set()

    scored = []

    for outfit in outfits:
        if outfit.id == target_outfit_id:
            continue

        try:
            score = jaccard_similarity(target_tags, outfit.tag_set())
            scored.append((outfit, round(score, 4)))
        except Exception:
            continue

    # 🔥 统一排序（修复你原来的分桶错误）
    scored.sort(key=lambda x: x[1], reverse=True)

    high = scored[:high_count]
    low = list(reversed(scored))[:low_count]

    return {
        "high": high,
        "low": low,
    }
